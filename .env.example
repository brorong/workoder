# ── 伺服器設定 ───────────────────────────────────────
PORT=5000
FLASK_ENV=production
BASE_URL=https://your-domain.com        # 對外的服務網址（用於產生施工連結）
ALLOWED_ORIGINS=https://your-domain.com # CORS 允許的前端來源

# ── 安全性 ───────────────────────────────────────────
ADMIN_TOKEN=please-change-this-strong-token   # 後台 API 驗證 Token

# ── 照片儲存 ─────────────────────────────────────────
UPLOAD_FOLDER=uploads
MAX_PHOTO_MB=10

# ── LINE Messaging API 通知 ──────────────────────────
# 1. 前往 https://developers.line.biz/console/ 建立 Provider → Messaging API Channel
# 2. 於 Channel 設定頁 → "Messaging API" 頁籤 → 取得「Channel access token (long-lived)」
# 3. 貼上 Token 至此
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token-here
# 後台接收通知的預設目標 ID：
#   - 要推給「群組」：在群組中加入 Bot 後，透過 webhook 取得 groupId（C 開頭）
#   - 要推給「個人」：取得 userId（U 開頭）
#   - 留空 → 使用 broadcast（推送給所有好友，每月有配額）
LINE_TARGET_ID=

# ── Email 通知 (SMTP) ────────────────────────────────
# Gmail 範例：需啟用「應用程式密碼」
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
